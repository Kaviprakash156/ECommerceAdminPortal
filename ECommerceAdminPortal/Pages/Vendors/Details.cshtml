@page "{id:int}"
@model ECommerceAdminPortal.Pages.Vendors.DetailsModel

<h2>Vendor Details</h2>

<div class="card">

    <div class="card-body">

        <p>
            <strong>Name:</strong>
            @Model.Vendor.VendorName
        </p>

        <p>
            <strong>Email:</strong>
            @Model.Vendor.Email
        </p>

        <p>
            <strong>Phone:</strong>
            @Model.Vendor.Phone
        </p>

        <p>
            <strong>Status:</strong>
            @(Model.Vendor.IsActive ? "Active" : "Inactive")
        </p>

    </div>

</div>

<a asp-page="Index"
   class="btn btn-secondary mt-3">
    Back
</a>