@page
@model ECommerceAdminPortal.Pages.Orders.IndexModel

<h2>Orders</h2>

<p>
    <a asp-page="Create"
       class="btn btn-primary">
        Create Order
    </a>
</p>

<table class="table table-bordered">

    <thead>

        <tr>

            <th>Order No</th>
            <th>Customer</th>
            <th>Date</th>
            <th>Total</th>
            <th>Status</th>
            <th>Action</th>

        </tr>

    </thead>

    <tbody>

        @foreach (var item in Model.Orders)
        {
            <tr>

                <td>@item.OrderId</td>

                <td>@item.CustomerName</td>

                <td>@item.OrderDate</td>

                <td>@item.TotalAmount</td>

                <td>
                    <a asp-page="Status"
                       asp-route-id="@item.OrderId"
                       asp-route-status="@item.Status"
                       class="btn btn-warning">

                        Status

                    </a>
                </td>

                <td>

                    <a asp-page="Details"
                       asp-route-id="@item.OrderId"
                       class="btn btn-info">

                        View

                    </a>

                </td>

            </tr>
        }

    </tbody>

</table>